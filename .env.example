# Local dev: either works (restart dev server after editing).
VITE_ANTHROPIC_API_KEY=

# Vercel / production (recommended): server-only key — not exposed in the JS bundle.
# Set ANTHROPIC_API_KEY in Vercel → Environment Variables → Redeploy.
# Optional fallback: VITE_ANTHROPIC_API_KEY on the server is also read by /api/claude.
